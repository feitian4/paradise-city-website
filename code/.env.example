# 环境变量配置
# 复制此文件为 .env.local 并填入真实值

# WalletConnect Project ID
# 从 https://cloud.walletconnect.com 获取
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# 智能合约地址（部署到 Polygon 后填入）
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=
NEXT_PUBLIC_TOKEN_CONTRACT_ADDRESS=

# API
NEXT_PUBLIC_API_URL=http://localhost:3000

# 数据库（预约系统）
DATABASE_URL=

# 邮件通知
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=contact@shangri-la-city.com
